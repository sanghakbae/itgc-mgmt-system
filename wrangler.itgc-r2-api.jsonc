{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "itgc-r2-api",
  "main": "workers/itgc-r2-api.js",
  "compatibility_date": "2026-06-15",
  "workers_dev": true,
  "r2_buckets": [
    {
      "binding": "ITGC_BUCKET",
      "bucket_name": "itgc"
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://itgc.sanghak.kr,https://sanghakbae.github.io,http://localhost:5180,http://127.0.0.1:5180"
  }
}
